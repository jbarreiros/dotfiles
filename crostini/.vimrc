syntax on
colorscheme slate

" text
set autoindent
set expandtab
set shiftround
set shiftwidth=2
set smarttab
set tabstop=2

" search
set ignorecase
set incsearch
set smartcase

" UI
set cursorline
set number
set colorcolumn=80
set laststatus=2
set showmode

" show extra whitespace
set listchars=tab:▹\ ,trail:·,nbsp:⚋
set fillchars=fold:-
set list
